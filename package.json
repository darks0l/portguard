{
  "name": "@darksol/portguard",
  "version": "1.0.0",
  "description": "Cross-platform CLI and API to inspect, monitor, and clear localhost port conflicts.",
  "author": "darksol",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "bin": {
    "portguard": "dist/esm/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true });\"",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "postbuild": "node scripts/postbuild.cjs",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.12",
    "typescript": "^5.8.2"
  },
  "keywords": [
    "ports",
    "cli",
    "networking",
    "developer-tools",
    "localhost",
    "devops"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darks0l/portguard.git"
  },
  "bugs": {
    "url": "https://github.com/darks0l/portguard/issues"
  },
  "homepage": "https://github.com/darks0l/portguard#readme"
}
